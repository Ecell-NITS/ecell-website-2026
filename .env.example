# ═══════════════════════════════════════════════════════════════
# E-Cell NIT Silchar — Frontend Environment Variables
# Copy this file to .env and fill in the values
#
# .env.example is committed to git (no secrets here)
# .env is gitignored — never commit it
# ═══════════════════════════════════════════════════════════════

# ── Backend API URL ──────────────────────────────────────────
# Points to the Express backend (e-cell-website-25-api)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── EIC Registration API URL (optional) ─────────────────────
# Only needed if running the EIC registration module
NEXT_PUBLIC_EIC_API_URL=http://localhost:4000
